# ═══════════════════════════════════════════════════════════════════════════
# RAGu configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and uncomment only what you want to change — every
# line below already shows its default value.
#
# Naming convention:
#   RAGU_<GROUP>__<KEY>=value   RAGu settings — note the DOUBLE underscore
#                               e.g. RAGU_RETRIEVAL__CANDIDATE_K=500
#   OPENAI_API_KEY=...          Provider keys have NO prefix; the provider SDKs
#                               read them directly.


# ─── Quick start ─────────────────────────────────────────────────────────────
# A typical setup only needs an API key (used for contextual chunking and L2
# reasoning) and, if you ingest images or scanned PDFs, OCR turned on. Everything
# else has working defaults.
#
# OPENAI_API_KEY=sk-...
# RAGU_OCR__ENABLED=true


# ─── Provider API keys (no RAGU_ prefix) ─────────────────────────────────────
# OPENAI_API_KEY=sk-...     # OpenAI or any OpenAI-compatible server
# VOYAGE_API_KEY=...        # only when RAGU_EMBEDDING__PROVIDER=voyage
# GEMINI_API_KEY=...        # (or GOOGLE_API_KEY) for any "gemini" provider


# ─── LLM: generic chat model ─────────────────────────────────────────────────
# Used for contextual-retrieval blurbs and other glue. Never tied to one vendor.
# RAGU_LLM__PROVIDER=openai_compat    # openai_compat | gemini | scripted
# RAGU_LLM__MODEL=gpt-4o-mini
# RAGU_LLM__BASE_URL=                 # set to reach a self-hosted / Anthropic-compat endpoint
# RAGU_LLM__API_KEY=                  # falls back to the provider SDK's env var
# RAGU_LLM__TEMPERATURE=0.0


# ─── Embedding ───────────────────────────────────────────────────────────────
# Provider: local (sentence-transformers, needs the `local` extra) | voyage | fake
# RAGU_EMBEDDING__PROVIDER=local
# RAGU_EMBEDDING__MODEL=intfloat/multilingual-e5-small
# RAGU_EMBEDDING__DIM=384             # informational; local reports the true dim
# RAGU_EMBEDDING__BATCH_SIZE=64
# RAGU_EMBEDDING__DEVICE=cpu          # cpu | cuda | cuda:0
# RAGU_EMBEDDING__NORMALIZE=true
#
# Asymmetric prefixes (E5 wants these). Set BOTH empty for models that don't use
# instructions, e.g. BGE-M3. Note the trailing space in real values.
# RAGU_EMBEDDING__QUERY_PREFIX=query:
# RAGU_EMBEDDING__DOCUMENT_PREFIX=passage:
#
# Advanced:
# RAGU_EMBEDDING__QUERY_PROMPT_NAME=       # use the model's registered ST prompt instead of a prefix
# RAGU_EMBEDDING__DOCUMENT_PROMPT_NAME=
# RAGU_EMBEDDING__TRUST_REMOTE_CODE=false  # needed by models shipping custom code
#
# Alternative: Snowflake Arctic v2.0 — stronger, 768-dim, GPU-ish:
# RAGU_EMBEDDING__MODEL=Snowflake/snowflake-arctic-embed-m-v2.0
# RAGU_EMBEDDING__DIM=768
# RAGU_EMBEDDING__DEVICE=cuda
# RAGU_EMBEDDING__QUERY_PROMPT_NAME=query  # Arctic ships its own query prompt
# RAGU_EMBEDDING__DOCUMENT_PREFIX=         # Arctic docs get NO prefix
# RAGU_EMBEDDING__TRUST_REMOTE_CODE=true


# ─── Chunking ────────────────────────────────────────────────────────────────
# Contextual retrieval needs the LLM above; set CONTEXTUAL=false to run offline.
# RAGU_CHUNKING__TARGET_TOKENS=400
# RAGU_CHUNKING__OVERLAP_TOKENS=64
# RAGU_CHUNKING__CONTEXTUAL=true
# RAGU_CHUNKING__CONTEXT_MODEL=       # optional cheaper model for the blurbs


# ─── OCR (PP-OCRv6 via PaddleOCR) ────────────────────────────────────────────
# Needs the `ocr` extra + a paddle runtime. Off by default.
# RAGU_OCR__ENABLED=false
# RAGU_OCR__LANG=en
# RAGU_OCR__DEVICE=cpu                # cpu | gpu:0  (install paddlepaddle-gpu for GPU)
#
# PDF strategy:
#   auto — use the text layer, OCR only text-poor pages (fast, default)
#   ocr  — OCR every page, ignore the text layer (best for bad scans)
#   text — text layer only, never OCR
# RAGU_OCR__PDF_MODE=auto
# RAGU_OCR__PDF_DPI=200
# RAGU_OCR__PDF_MIN_TEXT_CHARS=16     # below this, an "auto" page is OCR'd
#
# Advanced — model selection & tuning (blank = PaddleOCR's PP-OCRv6 defaults):
# RAGU_OCR__DET_MODEL_NAME=           # or PP-OCRv6_{tiny,small,medium}_det
# RAGU_OCR__REC_MODEL_NAME=           # or PP-OCRv6_{tiny,small,medium}_rec
# RAGU_OCR__DET_MODEL_DIR=            # local model dir (overrides the name)
# RAGU_OCR__REC_MODEL_DIR=
# RAGU_OCR__ENABLE_MKLDNN=false       # keep false: paddle 3.x CPU oneDNN crashes on PP-OCRv6
# RAGU_OCR__DET_LIMIT_SIDE_LEN=       # detection resolution; raise on a roomy GPU
# RAGU_OCR__DET_LIMIT_TYPE=           # max (cap longest side) | min (paddle default)
# RAGU_OCR__REC_BATCH_SIZE=           # lower to cut peak VRAM


# ─── Storage ─────────────────────────────────────────────────────────────────
# RAGU_STORAGE__BACKEND=lance         # lance (persistent) | memory (ephemeral, dev/tests)
# RAGU_STORAGE__LANCEDB_URI=./.ragu/lancedb
# RAGU_STORAGE__CHUNKS_TABLE=chunks
# RAGU_STORAGE__DOCUMENTS_TABLE=documents


# ─── Retrieval (L1, optional pre-filter) ─────────────────────────────────────
# Only used when RAGU_VOMERO__FULL_CORPUS=false. L1 casts a wide net: it narrows
# the corpus to a working set for L2, it does not find the final answer.
# RAGU_RETRIEVAL__CANDIDATE_K=200     # chunks per channel before fusion
# RAGU_RETRIEVAL__RRF_K=60            # reciprocal-rank-fusion constant
# RAGU_RETRIEVAL__RERANK=false
# RAGU_RETRIEVAL__RERANK_TOP_K=50
# RAGU_RETRIEVAL__DOCUMENT_K=100      # parent docs handed toward the working set


# ─── Working set ─────────────────────────────────────────────────────────────
# The real bound on L2 cost is tokens, not document count.
# RAGU_WORKING_SET__MAX_TOKENS=150000


# ─── Memory ──────────────────────────────────────────────────────────────────
# RAGU_MEMORY__SESSION_MAX_BYTES=268435456   # 256 MiB per-session working-set LRU
# RAGU_MEMORY__WARM_BOOST=0.1                 # score boost for warm docs in L1
# RAGU_MEMORY__PREFERENCES_ENABLED=false      # mem0 (not yet implemented)


# ─── L2 reasoning (vomero) ───────────────────────────────────────────────────
# Needs the `l2` extra. If API_KEY is unset, vomero falls back to
# OPENAI_API_KEY / GEMINI_API_KEY.
# RAGU_VOMERO__PROVIDER=openai        # openai | gemini
# RAGU_VOMERO__MODEL=gpt-4o-mini
# RAGU_VOMERO__BASE_URL=              # self-hosted / Anthropic-compat endpoint
# RAGU_VOMERO__API_KEY=
# RAGU_VOMERO__HANDOFF=corpus         # corpus (folder, enables citations) | context (in-memory)
#
# Main approach — agentic RAG over the WHOLE corpus (on by default): L1 retrieval
# is skipped and vomero reasons (search/grep/read/recurse) over every indexed
# document, so dense recall never caps the answer. Set false to pre-filter with
# the L1+L2 pipeline first — fine when the set is simple and isn't multi-hop.
# RAGU_VOMERO__FULL_CORPUS=true
#
# Persistent lexical search index backing L2's corpus.search() (BM25, built once,
# opened read-only; the web server warms it at startup). Empty => next to the
# LanceDB store; set "off" to disable (grep-only navigation).
# RAGU_VOMERO__SEARCH_INDEX_DIR=
#
# Inline citation grounding (extra LLM call via RAGU_LLM__*; off by default):
# RAGU_VOMERO__GROUND_CITATIONS=false
# RAGU_VOMERO__GROUNDING_SOURCE=trajectory   # trajectory (LLM) | document (LLM) | raw (no LLM)
#
# Loop limits & budgets:
# RAGU_VOMERO__MAX_STEPS=24
# RAGU_VOMERO__MAX_DEPTH=3
# RAGU_VOMERO__MAX_PARALLEL_CALLS=8
# RAGU_VOMERO__MAX_TOTAL_TOKENS=0     # 0 = unlimited
# RAGU_VOMERO__MAX_TOTAL_CALLS=0      # 0 = unlimited
# RAGU_VOMERO__CONTEXT_WINDOW=128000
# RAGU_VOMERO__COMPACT_RATIO=0.8
# RAGU_VOMERO__MAX_OUTPUT_CHARS=10000
# RAGU_VOMERO__PLAN=false             # show a live TODO plan
# RAGU_VOMERO__SANDBOX=false          # true => gVisor isolation (untrusted corpora)
# RAGU_VOMERO__VERBOSE=false          # true => stream L2's per-step trace (code/output/usage) to stderr
# RAGU_VOMERO__INTERACTIVE=true       # let L2 ask a clarifying question (prompts on a TTY; degrades headless)
